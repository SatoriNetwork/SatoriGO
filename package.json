{
  "name": "satori-go-wallet",
  "version": "1.1.0",
  "private": true,
  "license": "MIT",
  "description": "EVRmore + SATORI browser wallet for the Satori Network (real network).",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/build.mjs --target=all",
    "build:chrome": "node scripts/build.mjs --target=chrome",
    "build:edge": "node scripts/build.mjs --target=edge",
    "build:firefox": "node scripts/build.mjs --target=firefox",
    "preview": "vite preview --port 4173 --strictPort",
    "test": "vitest run",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "icons": "node scripts/generate-icons.mjs",
    "package": "node scripts/package.mjs",
    "package:chrome": "node scripts/package.mjs --target=chrome",
    "package:edge": "node scripts/package.mjs --target=edge",
    "package:firefox": "node scripts/package.mjs --target=firefox",
    "qa:live": "node scripts/live-extension-smoke.mjs",
    "qa:dapp": "node scripts/dapp-smoke.mjs"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@noble/hashes": "^1.6.1",
    "@noble/secp256k1": "^2.2.3",
    "@scure/base": "^1.2.1",
    "@scure/bip32": "^1.6.0",
    "@scure/bip39": "^1.5.0",
    "lucide-react": "^0.468.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/adm-zip": "^0.5.7",
    "@types/chrome": "^0.0.287",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.3.14",
    "@types/react-dom": "^18.3.2",
    "@vitejs/plugin-react": "^4.3.4",
    "adm-zip": "^0.5.16",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.13.0",
    "jsdom": "^25.0.1",
    "playwright": "^1.49.1",
    "sharp": "^0.33.5",
    "typescript": "~5.6.3",
    "typescript-eslint": "^8.18.0",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
